# Supabase PostgreSQL
# ВАЖНО: если в пароле есть $, !, # и т.п. — обязательно в двойных кавычках:
# DB_PASSWORD="your$password!"
DB_HOST=aws-0-eu-west-3.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.igftkxezlsdqkzrjobux
DB_PASSWORD="YOUR-PASSWORD-HERE"

# Object storage — local dev (docker compose up -d minio)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=vault-assets

# Production — Cloudflare R2 (SPRING_PROFILES_ACTIVE=prod)
# STORAGE_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# STORAGE_ACCESS_KEY=<R2 Access Key ID from API token>
# STORAGE_SECRET_KEY=<R2 Secret Access Key from API token>
# STORAGE_BUCKET=vault-assets
# STORAGE_REGION=auto
# STORAGE_AUTO_CREATE_BUCKET=false

# JWT (минимум 32 символа)
JWT_SECRET=change-me-to-a-secure-256-bit-secret-key-for-production-use
